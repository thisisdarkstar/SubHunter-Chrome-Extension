{
  "manifest_version": 3,
  "name": "SubHunter",
  "version": "1.0.0",
  "description": "Discover subdomains via Certificate Transparency logs, DNS brute-force, and verify live hosts - all offline-capable with free APIs",
  "author": "SubHunter",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://crt.sh/*",
    "https://dns.google/*",
    "https://api.certspotter.com/*",
    "https://api.subdomain.center/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "SubHunter - Subdomain Scanner"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
